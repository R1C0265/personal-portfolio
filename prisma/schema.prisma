// Prisma schema for Personal Developer Portfolio
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum SkillCategory {
  FRONTEND
  BACKEND
  FULL_STACK
  TOOLS
  DATABASE
  DEVOPS
  OTHER
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum MessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

// ─── USER ─────────────────────────────────────────────────────────────────────
// Admin user for portfolio management

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Always stored as bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PROJECT ───────────────────────────────────────────────────────────────────
// Showcase your portfolio projects

model Project {
  id              String   @id @default(cuid())
  title           String
  description     String   @db.Text      // Short description for cards
  longDescription String?  @db.LongText  // Detailed description for project page
  imageUrl        String?                // Main project image
  galleryImages   Json?                 // Additional images as JSON array
  technologies    Json                  // Tech stack as JSON array (e.g., ["React", "Node.js", "PostgreSQL"])
  liveUrl         String?                // URL to live project
  githubUrl       String?                // GitHub repository link
  featured        Boolean  @default(false) // Show on homepage
  sortOrder       Int      @default(0)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── EXPERIENCE ────────────────────────────────────────────────────────────────
// Work experience and employment history

model Experience {
  id              String   @id @default(cuid())
  company         String
  position        String   // e.g. "Senior Full Stack Developer"
  description     String   @db.Text
  technologies    Json?                 // Tech stack at this job
  startDate       DateTime
  endDate         DateTime? // NULL if current position
  isCurrent       Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── SKILL ─────────────────────────────────────────────────────────────────────
// Programming skills, languages, frameworks, and tools

model Skill {
  id              String          @id @default(cuid())
  name            String          // e.g. "React", "TypeScript", "Docker"
  category        SkillCategory
  proficiency     ProficiencyLevel
  yearsOfExperience Int?
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ─── CONTACT MESSAGE ───────────────────────────────────────────────────────────
// Visitor messages from the contact form

model ContactMessage {
  id          String         @id @default(cuid())
  name        String
  email       String
  subject     String
  message     String         @db.Text
  status      MessageStatus  @default(NEW)
  isRead      Boolean        @default(false)
  repliedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ─── INQUIRY ───────────────────────────────────────────────────────────────────
// Product inquiries from the order form

model Inquiry {
  id              String         @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String?
  productId       String
  quantity        Int
  preferredContact String?
  message         String         @db.Text
  status          MessageStatus  @default(NEW)
  isRead          Boolean        @default(false)
  repliedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  notes           Note[]
}

// ─── NOTE ──────────────────────────────────────────────────────────────────────
// Notes on inquiries

model Note {
  id          String   @id @default(cuid())
  inquiryId   String
  inquiry     Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── SOCIAL LINK ───────────────────────────────────────────────────────────────
// Your social media and professional links

model SocialLink {
  id          String   @id @default(cuid())
  platform    String   // e.g. "GitHub", "LinkedIn", "Twitter", "Email"
  url         String
  icon        String?  // Icon identifier for frontend
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── ARTICLE (OPTIONAL) ────────────────────────────────────────────────────────
// Blog articles or technical writeups

model Article {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String   @db.Text
  content         String   @db.LongText
  imageUrl        String?
  featured        Boolean  @default(false)
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

